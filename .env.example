# Nstbrowser — get your API key from the Nstbrowser dashboard (nstbrowser.io)
NSTBROWSER_API_KEY=your_nstbrowser_api_key_here

# DataImpulse — get credentials from your dashboard (dataimpulse.com)
DI_USER=your_dataimpulse_username
DI_PASS=your_dataimpulse_password

# Optional: Nstbrowser local host (default: localhost:8848)
NSTBROWSER_HOST=localhost:8848

# MostLogin — API key from the MostLogin desktop app (Settings > API)
MOSTLOGIN_API_KEY=your_mostlogin_api_key_here

# Optional: MostLogin local API host (default: 127.0.0.1:30898)
MOSTLOGIN_HOST=127.0.0.1:30898

# Optional flow tuning (defaults shown)
# Site profile to run (available: eurocookflow, focusclock)
BOT_SITE_PROFILE=eurocookflow

# MostLogin scheduled runner tuning (npm run start:mostlogin:schedule)
# Rounds launched before scheduler stops creating new sessions.
ML_SCHEDULE_ROUNDS=180
# Max sessions launched per round.
ML_SCHEDULE_PROFILES_PER_ROUND=1
# Delay between rounds in milliseconds.
ML_SCHEDULE_ROUND_INTERVAL_MS=10000
# Delay between launches within the same round (milliseconds).
ML_SCHEDULE_LAUNCH_STAGGER_MS=0

FLOW_MIN_DURATION_MS=150000
FLOW_MIN_UNIQUE_PAGES=6
FLOW_TOPUP_MAX_CYCLES=8
FLOW_TELEMETRY_DIR=telemetry
FLOW_TRAFFIC_BREAKDOWN_LIMIT=20
FLOW_MAX_SIGNUP_VISITS=1
FLOW_MAX_DASHBOARD_EXTRA_PAGES=1

# Patchright concurrency/runtime tuning
# Target concurrent sessions
CONCURRENCY=20
# Lower bound for adaptive backoff logic
MIN_CONCURRENCY=10
# Shared browser mode: one Chromium process, many isolated contexts.
# Recommended on Railway when aiming for high concurrency.
SHARED_BROWSER_MODE=1
# Number of identical Railway replicas sharing the workload.
# For strict sharding, pair this with REPLICA_SHARD_INDEX on separate services
# or another coordination layer. Same-service replicas can only do best-effort sharding.
REPLICA_SHARD_COUNT=1
# Optional explicit zero-based shard index for coordinated workers.
# Example for 3 workers: 0, 1, 2
# REPLICA_SHARD_INDEX=0
# Launch stagger in ms between concurrent sessions (0 = launch all immediately)
SESSION_LAUNCH_STAGGER_MS=1000
# Safety guard for long-running sessions
SESSION_TIMEOUT_MS=240000
# Keep heartbeat + memory logs visible
ALIVE_LOG_INTERVAL_MS=30000

# Optional cache-audit target (used by: npm run audit:cache)
AUDIT_BASE_URL=https://eurocookflow.com

# Tunnel-backed MostLogin access from Railway
MOSTLOGIN_TUNNEL_URL=https://mostlogin.example.com
MOSTLOGIN_TUNNEL_BEARER=replace_me

# Patchright profile source and persistence controls
PROFILE_SOURCE=mostlogin
ALLOW_GENERATOR_FALLBACK=0
SESSION_STATE_POLICY=identity-sticky
PATCHRIGHT_CACHE_DIR=/data/marketingbot-patchright

# Strict shard ownership
REPLICA_SHARD_COUNT=1
# REPLICA_SHARD_INDEX=0

# Debug-only extension request visibility
NETWORK_DEBUG=0
