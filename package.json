{
  "name": "marketingbot",
  "version": "1.0.1",
  "description": "",
  "main": "index.js",
  "scripts": {
    "start": "ts-node src/index.ts",
    "start:mostlogin": "ts-node src/index.mostlogin.ts",
    "start:mostlogin:schedule": "ts-node src/index.mostlogin.scheduled.ts",
    "start:mostlogin:tunnel-proxy": "ts-node src/scripts/mostloginTunnelProxy.ts",
    "bridge:run:proxy": "bash scripts/run-mostlogin-tunnel-proxy.sh",
    "bridge:run:cloudflared": "bash scripts/run-mostlogin-cloudflared.sh",
    "bridge:install:launchd": "bash scripts/install-mostlogin-bridge-launchd.sh",
    "create:profiles": "ts-node src/scripts/createProfiles.ts",
    "audit:cache": "ts-node src/scripts/auditCacheHeaders.ts",
    "build": "tsc",
    "start:js": "node dist/index.js",
    "mcp": "ts-node src/mcp/server.ts",
    "mcp:mostlogin": "ts-node src/mcp/mostlogin/server.ts",
    "mcp:patchright": "ts-node src/mcp/patchright/server.ts",
    "start:patchright": "BOT_SITE_PROFILE=eurocookflow ts-node src/index.patchright.ts",
    "start:guidenza": "BOT_SITE_PROFILE=guidenza ts-node src/index.patchright.ts",
    "check:similarweb": "ts-node src/scripts/checkSimilarwebSignal.ts",
    "telemetry:dashboard": "ts-node src/observability/dashboardServer.ts",
    "telemetry:bot-sessions": "ts-node src/observability/botSessionDashboard.ts",
    "telemetry:ext-network": "ts-node src/observability/extensionNetworkDashboard.ts",
    "telemetry:extension-watch": "ts-node --transpile-only src/scripts/extensionTelemetrySession.ts",
    "telemetry:extension-watch:display": "bash scripts/with-display.sh ts-node --transpile-only src/scripts/extensionTelemetrySession.ts",
    "telemetry:probe": "ts-node --transpile-only src/scripts/probeExtensionTelemetry.ts",
    "warmup:run": "ts-node --transpile-only src/scripts/cookieWarmup.ts",
    "warmup:quick": "WARMUP_MODE=quick ts-node --transpile-only src/scripts/cookieWarmup.ts",
    "warmup:run:display": "bash scripts/with-display.sh ts-node --transpile-only src/scripts/cookieWarmup.ts",
    "warmup:quick:display": "bash scripts/with-display.sh env WARMUP_MODE=quick ts-node --transpile-only src/scripts/cookieWarmup.ts",
    "ga:report": "ts-node src/scripts/checkGaReport.ts",
    "test:unit": "vitest run",
    "test:watch": "vitest",
    "pull:extensions": "ts-node src/scripts/pullExtensions.ts",
    "pull:catalog": "ts-node src/scripts/pullMostloginCatalog.ts",
    "import:mostlogin:extensions": "MOSTLOGIN_CHROME_EXTENSIONS_DIR=\"$HOME/Library/Application Support/MostLogin/chromeExtension\" ts-node src/scripts/importMostLoginExtensions.ts --write-manifest"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "@types/express": "^5.0.6",
    "axios": "^1.13.5",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "patchright": "^1.58.2",
    "patchright-mcp": "^0.0.68",
    "playwright": "^1.58.2",
    "ts-node": "^10.9.2",
    "ws": "^8.21.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "@types/node": "^25.3.0",
    "@types/ws": "^8.18.1",
    "typescript": "^5.9.3",
    "vitest": "^4.1.4"
  }
}
