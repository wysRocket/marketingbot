# ── proxy-cheap.com (paid) ────────────────────────────────────────────────────
# When both are set the service fetches YOUR purchased proxies from the API.
# When absent it falls back to free public SOCKS5 sources.
PROXYCHEAP_API_KEY=
PROXYCHEAP_API_SECRET=

# ── Sticky sessions ────────────────────────────────────────────────────────────
# Default TTL for sticky sessions (milliseconds).
# GET /proxy?session=my-id  → returns the same proxy for this long.
# Can be overridden per-request with ?ttl=<ms>.
# Examples: 60000 = 1 min, 600000 = 10 min, 3600000 = 1 hour
STICKY_TTL_MS=600000

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3001

# ── Refresh ───────────────────────────────────────────────────────────────────
REFRESH_INTERVAL_MS=1800000

# ── Validator ─────────────────────────────────────────────────────────────────
VALIDATE_TIMEOUT_MS=5000
VALIDATE_CONCURRENCY=60
