all": false, "source_file": "/Users/wysmyfree/Projects/marketingbot/mostlogin-extensions/mlomiejdfkolichcflejclcbmpeaniij/npm/@whotracksme/reporting/reporting/src/alive-check.js", "source_location": "L42"}, {"caller_nid": "src_alive_check_ping", "callee": "catch", "is_member_call": true, "source_file": "/Users/wysmyfree/Projects/marketingbot/mostlogin-extensions/mlomiejdfkolichcflejclcbmpeaniij/npm/@whotracksme/reporting/reporting/src/alive-check.js", "source_location": "L56"}, {"caller_nid": "src_alive_check_check", "callee": "(async () => {\n\t\t\ttry {\n\t\t\t\tlogger_default.debug(\"Checking whether a hourly ping should be sent...\");\n\t\t\t\tconst lastSent = await this.storage.get(this.storageKey);\n\t\t\t\tconst updateSentAt = () => this.storage.set(this.storageKey, { sentAt: now });\n\t\t\t\tif (!lastSent) {\n\t\t\t\t\tlogger_default.info(\"Last alive check not found. This should only happen on the first time the extension is started.\");\n\t\t\t\t\tawait updateSentAt();\n\t\t\t\t\treturn;\n\t\t\t\t} else if (lastSent.sentAt > now) {\n\t\t\t\t\tconst now_ = new Date(now);\n\t\t\t\t\tconst sentAt_ = new Date(lastSent.sentAt);\n\t\t\t\t\tlogger_default.warn(`Clock jump detected (now=${now_} but sentAt=${sentAt_} is in the future). Resetting counter.`);\n\t\t\t\t\tawait updateSentAt();\n\t\t\t\t\treturn;\n\t\t\t\t} else if (lastSent.sentAt + HOUR > now) {\n\t\t\t\t\tlogger_default.debug(\"Checking whether a hourly ping should be sent... No reached yet.\");\n\t\t\t\t\tthis._skipChecksUntil = lastSent.sentAt + HOUR;\n\t\t\t\t\treturn;\n\t\t\t\t}\n\t\t\t\tlogger_default.debug(\"Hourly ping reached. Sending...\");\n\t\t\t\tawait this._reportAlive();\n\t\t\t\tthis._skipChecksUntil = now + HOUR;\n\t\t\t\tlogger_default.debug(\"Hourly ping successfully sent. Saving state...\");\n\t\t\t\tawait updateSentAt();\n\t\t\t\tlogger_default.debug(\"Hourly ping succeeded.\");\n\t\t\t} finally {\n\t\t\t\tthis._pendingUpdate = null;\n\t\t\t}\n\t\t})", "is_member_call": false, "so