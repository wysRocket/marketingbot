(\"Failed to update country. Cooldown until:\", new Date(this.ctryInfo.skipAttemptsUntil), e);\n\t\t\t\t\tthrow e;\n\t\t\t\t}\n\t\t\t} finally {\n\t\t\t\tawait this._syncCacheToDisk();\n\t\t\t\tthis._pendingUpdate = null;\n\t\t\t}\n\t\t})", "is_member_call": false, "source_file": "/Users/wysmyfree/Projects/marketingbot/mostlogin-extensions/mlomiejdfkolichcflejclcbmpeaniij/npm/@whotracksme/reporting/reporting/src/country-provider.js", "source_location": "L101"}, {"caller_nid": "src_country_provider_nonblockingupdateinbackground", "callee": "catch", "is_member_call": true, "source_file": "/Users/wysmyfree/Projects/marketingbot/mostlogin-extensions/mlomiejdfkolichcflejclcbmpeaniij/npm/@whotracksme/reporting/reporting/src/country-provider.js", "source_location": "L147"}, {"caller_nid": "src_country_provider_synccachetodisk", "callee": "set", "is_member_call": true, "source_file": "/Users/wysmyfree/Projects/marketingbot/mostlogin-extensions/mlomiejdfkolichcflejclcbmpeaniij/npm/@whotracksme/reporting/reporting/src/country-provider.js", "source_location": "L153"}, {"caller_nid": "src_country_provider_synccachetodisk", "callee": "error", "is_member_call": true, "source_file": "/Users/wysmyfree/Projects/marketingbot/mostlogin-extensions/mlomiejdfkolichcflejclcbmpeaniij/npm/@whotracksme/reporting/reporting/src/country-provider.js", "source_location": "L155"}, {"caller_nid": "src_country_provider_sanitizecountry", "callee": "includes", "is_member_call": true, "source_file": "/Users/wysmyfree/Projects/marketingbot/mostlogin-extensions/mlomiejdfkolichcflejclcbmpeaniij/npm/@whotracksme/reporting/reporting/src/country-provider.js", "source_location": "L178"}, {"caller_nid": "src_country_provider_validatectryinfo", "callee": "checkCtry", "is_member_call": false, "source_file": "/Users/wysmyfree/Projects/marketingbot/mostlogin-extensions/mlomiejdfkolichcflejclcbmpeaniij/npm/@whotracksme/reporting/reporting/src/country-provider.js", "source_location": "L198"}, {"caller_nid": "src_cou