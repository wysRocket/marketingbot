# Copy this file to .mostlogin-bridge.env and fill in your local values.

# Local MostLogin desktop API bridge
MOSTLOGIN_API_KEY=replace_me
MOSTLOGIN_HOST=127.0.0.1:30898
MOSTLOGIN_TUNNEL_BEARER=replace_me
MOSTLOGIN_TUNNEL_PORT=30908

# Named Cloudflare tunnel that exposes the local bridge
MOSTLOGIN_CLOUDFLARED_TUNNEL=replace_with_tunnel_name
MOSTLOGIN_CLOUDFLARED_CONFIG=/Users/your-user/.cloudflared/mostlogin-cloudflared.yml
